rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * MAHARANA PRATAP ITI SECURITY RULES
     * 
     * CORE PHILOSOPHY:
     * This ruleset implements a dual-layer security model: Database-Backed Access Control (DBAC) 
     * for administrators and a strict Ownership model for students. Authentication via Firebase 
     * Auth is required for all non-public interactions.
     */

    // --- Global Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    /**
     * @description Global site configuration (Logo, Stamp, Address).
     * @path /siteSettings/config
     */
    match /siteSettings/config {
      allow get: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Public admission inquiries.
     * @path /inquiries/{inquiryId}
     */
    match /inquiries/{inquiryId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    /**
     * @description Student profiles and registration data.
     * @path /students/{studentId}
     */
    match /students/{studentId} {
      allow get, list: if isAdmin() || isOwner(studentId);
      allow create: if true; // Allow initial portal registration
      allow update: if isAdmin() || isOwner(studentId);
      allow delete: if isAdmin();
    }

    /**
     * @description Registry for administrative users.
     * @path /roles_admin/{adminUid}
     */
    match /roles_admin/{adminUid} {
      allow get: if isSignedIn();
      allow list, create, update, delete: if false;
    }

    /**
     * @description Collection of courses/trades offered by the ITI.
     */
    match /trades/{tradeId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Academic assignments.
     */
    match /assignments/{assignmentId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Student results and submissions.
     */
    match /results/{resultId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.studentId == request.auth.uid);
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    /**
     * @description Financial records for student fees.
     */
    match /fees/{feeId} {
      allow get, list: if isAdmin() || (isSignedIn() && resource.data.studentId == request.auth.uid);
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    /**
     * @description Global announcements.
     */
    match /notifications/{notificationId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }
  }
}