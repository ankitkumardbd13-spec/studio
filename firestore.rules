
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow admins full access
    match /{document=**} {
      allow read, write: if request.auth != null && request.auth.token.admin == true;
    }

    // Student access to their own profile
    match /students/{studentId} {
      allow read: if request.auth != null && request.auth.uid == studentId;
      allow create: if true; // Allow portal registration
      allow update: if request.auth != null && request.auth.uid == studentId;
    }

    // Public inquiries
    match /inquiries/{inquiryId} {
      allow create: if true;
      allow read, write: if request.auth != null && request.auth.token.admin == true;
    }

    // Access to assignments and results
    match /assignments/{assignmentId} {
      allow read: if request.auth != null;
    }
    
    match /results/{resultId} {
      allow read: if request.auth != null && (resource.data.studentId == request.auth.uid || request.auth.token.admin == true);
      allow create: if request.auth != null;
    }
    
    // Public access to site settings for the homepage
    match /siteSettings/{config} {
      allow read: if true;
    }
  }
}
