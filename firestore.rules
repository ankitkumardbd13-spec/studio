
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Site settings are public for branding (logo, address)
    match /siteSettings/config {
      allow get: if true;
      allow write: if isAdmin();
    }

    // Inquiries can be submitted by anyone
    match /inquiries/{inquiryId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Students can register themselves or be managed by admin
    match /students/{studentId} {
      allow get, list: if isAdmin() || isOwner(studentId);
      allow create: if true;
      allow update: if isAdmin() || isOwner(studentId);
      allow delete: if isAdmin();
    }

    // Admin role registry
    match /roles_admin/{adminUid} {
      allow get: if isSignedIn();
      allow write: if false;
    }

    // Assignments and Results
    match /assignments/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /results/{id} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.studentId == request.auth.uid);
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /manual_submissions/{id} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.studentId == request.auth.uid);
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // Fees
    match /fees/{id} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.studentId == request.auth.uid);
      allow write: if isAdmin();
    }
    // Frontend mapping collections
    match /notifications/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /gallery/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /alumniReviews/{id} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }
    match /syllabus/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
